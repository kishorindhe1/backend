# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=healthcare_db
DB_USER=healthcare_user
DB_PASSWORD=your_strong_password_here
DB_POOL_MAX=10
DB_POOL_MIN=2

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_string_for_access_token
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex_string_for_refresh

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN_SECONDS=60
OTP_LOCKOUT_MINUTES=30

# ── SMS — MSG91 (primary) ─────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=HLTHBK
MSG91_TEMPLATE_ID=

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Phase 2 ───────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

PLATFORM_FEE_PERCENTAGE=2
SLOT_GENERATION_DAYS_AHEAD=30
